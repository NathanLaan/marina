{
  "name": "marina",
  "version": "1.0.1",
  "private": true,
  "workspaces": ["packages/*", "packages/desktop-ui/examples/*", "apps/*"],
  "scripts": {
    "build":                "npm run build -ws --if-present",
    "dev:noteliner":        "npm run dev -w noteliner",
    "dev:threadliner":      "npm run dev -w threadliner",
    "electron:noteliner":   "npm run electron:dev -w noteliner",
    "electron:threadliner": "npm run electron:dev -w threadliner",
    "playground":           "npm run electron:dev -w @marina/desktop-ui-playground",
    "build:noteliner":      "npm run build -w noteliner",
    "build:threadliner":    "npm run build -w threadliner",
    "icons:rasterize":      "npm run icons:rasterize:noteliner && npm run icons:rasterize:threadliner",
    "icons:rasterize:noteliner":   "electron scripts/rasterize-icon.js apps/noteliner/assets/icon.svg apps/noteliner/assets/icon.png 512",
    "icons:rasterize:threadliner": "electron scripts/rasterize-icon.js apps/threadliner/assets/icon.svg apps/threadliner/assets/icon.png 512"
  },
  "engines": { "node": ">=20" },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "electron": "^41.2.0",
    "esbuild": "^0.23.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}