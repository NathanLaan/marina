{
  "name": "@marina/desktop-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared UI components, theme system, and Electron host helpers for Marina apps.",
  "svelte": "./src/index.js",
  "main": "./src/index.js",
  "exports": {
    ".":                 { "svelte": "./src/index.js", "default": "./src/index.js" },
    "./styles":          "./src/styles/global.css",
    "./theme":           "./src/theme/index.svelte.js",
    "./components":      "./src/components/index.js",
    "./settings":        "./src/settings/index.js",
    "./command-palette": "./src/command-palette/index.js",
    "./electron-host":   "./src/electron-host/index.cjs",
    "./preload":         "./src/preload/index.cjs"
  },
  "peerDependencies": {
    "svelte":   "^5.0.0",
    "electron": ">=28"
  },
  "scripts": {
    "pretest": "npm run build -w @marina/desktop-ui-playground",
    "test": "playwright test",
    "test:update:pretest": "npm run build -w @marina/desktop-ui-playground",
    "test:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  }
}
