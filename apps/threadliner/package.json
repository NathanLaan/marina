{
  "name": "threadliner",
  "version": "1.0.1",
  "description": "A desktop RSS reader built with Electron, Svelte, and Git-synced JSON",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "bundle:preload": "esbuild src/main/preload.js --bundle --platform=node --target=node20 --external:electron --outfile=dist/preload.cjs",
    "prebuild": "npm run bundle:preload",
    "build": "vite build",
    "build:icons": "bash scripts/build-icons.sh",
    "build:linux": "npm run build && npm run build:icons && electron-builder --linux",
    "build:win":   "npm run build && npm run build:icons && electron-builder --win",
    "build:mac":   "npm run build && npm run build:icons && electron-builder --mac",
    "build:all":   "npm run build && npm run build:icons && electron-builder -mwl",
    "electron:dev": "node scripts/dev.js",
    "start": "electron --class=ThreadLiner .",
    "postinstall": "bash scripts/install-desktop.sh"
  },
  "dependencies": {
    "@marina/desktop-ui": "*",
    "@fortawesome/fontawesome-free": "^6.5.1",
    "dompurify": "^3.0.8",
    "electron-updater": "^6.8.3",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {},
    "build": {
    "appId": "com.threadline.app",
    "productName": "ThreadLiner",
    "files": [
      "src/main/**/*",
      "!src/main/preload.js",
      "dist/preload.cjs",
      "dist/renderer/**/*",
      "assets/icon.png"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network;Feed"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.news"
    },
    "win": {
      "target": ["nsis"]
    }
  }
  
}
