{
  "name": "threadliner",
  "version": "0.3.1",
  "description": "A desktop RSS reader built with Electron, Svelte, and Git-synced JSON",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "bundle:preload": "esbuild src/main/preload.js --bundle --platform=node --target=node20 --external:electron --outfile=dist/preload.cjs",
    "prebuild": "npm run bundle:preload",
    "build": "vite build",
    "electron:dev": "node scripts/dev.js",
    "start": "electron ."
  },
  "dependencies": {
    "@marina/desktop-ui": "*",
    "@fortawesome/fontawesome-free": "^6.5.1",
    "dompurify": "^3.0.8",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {},
    "build": {
    "appId": "com.threadline.app",
    "productName": "Threadliner",
    "files": [
      "src/main/**/*",
      "!src/main/preload.js",
      "dist/preload.cjs",
      "dist/renderer/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network;Feed"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.news"
    },
    "win": {
      "target": ["nsis"]
    }
  }
  
}
