{
  "name": "noteliner",
  "version": "0.7.1",
  "description": "An outliner-style note-taking app built with Electron and Svelte",
  "main": "src/main/main.js",
  "bin": {
    "noteliner-mcp-bridge": "bin/noteliner-mcp-bridge.js"
  },
  "author": {
    "name": "Nathan Laan"
  },
  "homepage": "https://github.com/NathanLaan/noteliner",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NathanLaan/noteliner.git"
  },
  "scripts": {
    "dev": "vite",
    "bundle:preload": "esbuild src/main/preload.js --bundle --platform=node --target=node20 --external:electron --outfile=dist/preload.cjs",
    "prebuild": "npm run bundle:preload",
    "build": "vite build",
    "build:icons": "bash scripts/build-icons.sh",
    "build:linux": "npm run build && npm run build:icons && electron-builder --linux",
    "build:win": "npm run build && npm run build:icons && electron-builder --win",
    "build:mac": "npm run build && npm run build:icons && electron-builder --mac",
    "build:all": "npm run build && npm run build:icons && electron-builder -mwl",
    "release": "npm run build && npm run build:icons && electron-builder --publish always",
    "start": "electron --class=NoteLiner .",
    "electron:dev": "node scripts/dev.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:mcp": "node tests/integration/mcp-bridge.test.js",
    "bench:gen": "node scripts/bench/generate-vault.js",
    "bench:run": "node scripts/bench/run-bench.js",
    "postinstall": "bash scripts/install-desktop.sh"
  },
  "keywords": [
    "outliner",
    "notes",
    "markdown",
    "electron",
    "svelte"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "@marina/desktop-ui": "*",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@fortawesome/fontawesome-free": "^6.7.0",
    "codemirror": "^6.0.1",
    "electron-updater": "^6.8.3",
    "gray-matter": "^4.0.3",
    "mammoth": "^1.12.0",
    "marked": "^15.0.0",
    "sortablejs": "^1.15.6",
    "uuid": "^14.0.0"
  }
}
